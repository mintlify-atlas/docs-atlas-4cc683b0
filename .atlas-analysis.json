  "keyFeatures": [
    "Source-accurate Swift syntax tree (SwiftSyntax) with full round-trip fidelity",
    "Pure-Swift parser (SwiftParser) with no toolchain dependency",
    "Swift macro authoring and expansion via SwiftSyntaxMacros and SwiftCompilerPlugin",
    "Result-builder-based code generation with SwiftSyntaxBuilder",
    "Structured diagnostics with fix-its via SwiftDiagnostics",
    "Code refactoring transformations via SwiftRefactor",
    "Incremental reparsing support for editor integrations",
    "IDE utilities including syntax classification and fix-it application"
  ],
  "publicApiSurface": [
    "SwiftSyntax — SyntaxProtocol, SyntaxVisitor, SyntaxRewriter, SyntaxCollection, TokenSyntax, Trivia",
    "SwiftParser — Parser.parse(source:), IncrementalParseTransition",
    "SwiftSyntaxBuilder — result builder DSL for constructing syntax nodes",
    "SwiftSyntaxMacros — Macro, ExpressionMacro, DeclarationMacro, AccessorMacro, MemberMacro, PeerMacro, ExtensionMacro, FreestandingMacro, AttachedMacro",
    "SwiftCompilerPlugin — CompilerPlugin protocol, @main entry point",
    "SwiftDiagnostics — Diagnostic, DiagnosticMessage, FixIt, Note, DiagnosticsFormatter",
    "SwiftRefactor — SyntaxRefactoringProvider, EditRefactoringProvider",
    "SwiftIDEUtils — SyntaxClassification, FixItApplier, NameMatcher",
    "SwiftOperators — OperatorTable, operator precedence folding",
    "SwiftBasicFormat — BasicFormat for canonical whitespace formatting",
    "SwiftIfConfig — compile-condition evaluation (#if/#else)",
    "SwiftLexicalLookup — lexical scope and name lookup"
  ]
}
